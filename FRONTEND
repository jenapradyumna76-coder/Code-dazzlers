              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <div
      id="modal"
      class="fixed inset-0 bg-slate-900/60 hidden items-center justify-center p-4 z-50 backdrop-blur-sm"
    >
      <div
        class="bg-white rounded-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto p-6 lg:p-10 relative shadow-2xl"
      >
        <button
          onclick="toggleModal(false)"
          class="absolute top-4 right-4 lg:top-6 lg:right-6 text-gray-400 hover:text-gray-900"
        >
          <i class="fas fa-times text-xl"></i>
        </button>
        <h3 class="text-xl lg:text-2xl font-bold text-gray-900 mb-1">
          Select Service Level
        </h3>
        <p class="text-xs lg:text-sm text-gray-500 mb-6 lg:mb-8">
          Choose your sanitization protocol.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-6">
          <div
            class="p-6 border border-gray-200 rounded-xl hover:border-slate-600 transition-all cursor-pointer group bg-slate-50/50"
          >
            <i class="fas fa-eraser text-2xl text-slate-600 mb-4"></i>
            <h4 class="font-bold text-sm lg:text-base mb-1">Software Wipe</h4>
            <p
              class="text-[10px] lg:text-xs text-gray-500 mb-4 leading-relaxed"
            >
              3-Pass software sanitization for magnetic media.
            </p>
            <div class="text-base lg:text-lg font-black text-slate-800">
              $49.00
            </div>
          </div>
          <div
            class="p-6 border border-gray-200 rounded-xl hover:border-slate-600 transition-all cursor-pointer group bg-slate-50/50"
          >
            <i class="fas fa-shredder text-2xl text-slate-600 mb-4"></i>
            <h4 class="font-bold text-sm lg:text-base mb-1">Physical Shred</h4>
            <p
              class="text-[10px] lg:text-xs text-gray-500 mb-4 leading-relaxed"
            >
              Cross-cut shredding with video verification.
            </p>
            <div class="text-base lg:text-lg font-black text-slate-800">
              $89.00
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      function switchTab(id) {
        document
          .querySelectorAll(".tab-content")
          .forEach((t) => t.classList.remove("active"));
        document
          .querySelectorAll(".nav-btn")
          .forEach((b) => b.classList.remove("active"));

        document.getElementById(id).classList.add("active");
        event.currentTarget.classList.add("active");

        // Update title on desktop
        const desktopTitle = document.getElementById("view-title");
        if (desktopTitle)
          desktopTitle.textContent = event.currentTarget.innerText;
      }

      function toggleModal(show) {
        document.getElementById("modal").style.display = show ? "flex" : "none";
      }

      function sendMessage() {
        const input = document.getElementById("chatInput");
        const container = document.getElementById("chatMessages");
        if (!input.value.trim()) return;

        // User side
        const userMsg = document.createElement("div");
        userMsg.className = "flex justify-end";
        userMsg.innerHTML = `<div class="bg-slate-600 text-white px-4 py-3 rounded-xl rounded-tr-none text-sm shadow-sm max-w-[85%]">${input.value}</div>`;
        container.appendChild(userMsg);

        input.value = "";
        container.scrollTop = container.scrollHeight;

        // Bot Response
        setTimeout(() => {
          const botMsg = document.createElement("div");
          botMsg.className = "flex justify-start";
          botMsg.innerHTML = `
                <div class="bg-white border border-gray-200 text-gray-800 px-4 py-3 rounded-xl rounded-tl-none text-sm shadow-sm max-w-[85%]">
                    Your request has been logged. An advisor will contact you shortly.
                </div>`;
          container.appendChild(botMsg);
          container.scrollTop = container.scrollHeight;
        }, 1000);
      }

      // Handle Enter key for mobile keyboards
      document.getElementById("chatInput").addEventListener("keypress", (e) => {
        if (e.key === "Enter") sendMessage();
      });
    </script>
  </body>
</html>
