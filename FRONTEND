          >
            <i class="fas fa-microchip w-5"></i> Hardware
          </button>
          <button
            onclick="switchTab('chatbot')"
            class="nav-btn whitespace-nowrap lg:whitespace-normal flex-shrink-0 w-auto lg:w-full flex items-center gap-3 px-4 py-3 lg:px-5 lg:py-4 rounded-lg font-semibold transition-all text-sm lg:text-base"
          >
            <i class="fas fa-comment-dots w-5"></i> AI Support
          </button>
          <button
            onclick="switchTab('reports')"
            class="nav-btn whitespace-nowrap lg:whitespace-normal flex-shrink-0 w-auto lg:w-full flex items-center gap-3 px-4 py-3 lg:px-5 lg:py-4 rounded-lg font-semibold transition-all text-sm lg:text-base"
          >
            <i class="fas fa-file-contract w-5"></i> Reports
          </button>
        </nav>

        <div
          class="hidden lg:block p-8 border-t border-gray-200 bg-slate-50 mt-auto"
        >
          <div
            class="text-xs font-bold text-gray-500 uppercase mb-3 tracking-widest"
          >
            System Health
          </div>
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
            <span class="text-xs font-medium text-gray-800"
              >API: Connected</span
            >
          </div>
        </div>
      </aside>

      <main class="flex-1 flex flex-col min-w-0">
        <header
          class="hidden lg:flex p-8 bg-white border-b border-gray-200 justify-between items-center"
        >
          <h2 id="view-title" class="text-2xl font-bold text-gray-900">
            Security Posture
          </h2>
          <div class="flex items-center gap-6">
            <i class="fas fa-bell text-gray-400 text-xl cursor-pointer"></i>
            <div
              class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center border border-gray-200"
            >
              <i class="fas fa-user-tie text-slate-500"></i>
            </div>
          </div>
        </header>

        <div class="p-4 lg:p-10 flex-1">
          <div
            id="cloud"
            class="tab-content active space-y-4 lg:space-y-8 animate-in fade-in"
          >
            <div
              class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-8"
            >
              <div
                class="p-6 lg:p-8 bg-white border border-gray-200 rounded-xl shadow-sm"
              >
                <i
                  class="fas fa-fingerprint text-slate-600 text-xl lg:text-2xl mb-4"
                ></i>
                <h3
                  class="text-gray-500 text-[10px] lg:text-xs font-bold uppercase tracking-widest mb-1"
                >
                  MFA Status
                </h3>
                <p class="text-xl lg:text-2xl font-black text-gray-900">
                  Active
                </p>
              </div>
              <div
                class="p-6 lg:p-8 bg-white border border-gray-200 rounded-xl shadow-sm"
              >
                <i
                  class="fas fa-database text-slate-600 text-xl lg:text-2xl mb-4"
                ></i>
                <h3
                  class="text-gray-500 text-[10px] lg:text-xs font-bold uppercase tracking-widest mb-1"
                >
                  Encryption
                </h3>
                <p class="text-xl lg:text-2xl font-black text-gray-900">
                  RSA-4096
                </p>
              </div>
              <div
                class="p-6 lg:p-8 bg-white border border-gray-200 rounded-xl shadow-sm sm:col-span-2 lg:col-span-1"
              >
                <i
                  class="fas fa-shield-heart text-slate-600 text-xl lg:text-2xl mb-4"
                ></i>
                <h3
                  class="text-gray-500 text-[10px] lg:text-xs font-bold uppercase tracking-widest mb-1"
                >
                  Audit Score
                </h3>
                <p class="text-xl lg:text-2xl font-black text-gray-900">
                  99.2%
                </p>
              </div>
            </div>

            <div
              class="bg-slate-800 rounded-xl p-6 lg:p-12 text-center text-white relative overflow-hidden"
            >
              <h3 class="text-xl lg:text-3xl font-bold mb-3">
                Asset Decommissioning
              </h3>
              <p
                class="text-slate-300 text-sm lg:text-base mb-6 lg:mb-8 max-w-2xl mx-auto"
              >
                Select a military-standard protocol for hardware disposal.
              </p>
              <button
                onclick="toggleModal(true)"
                class="w-full sm:w-auto bg-white text-slate-800 px-8 py-3 lg:py-4 rounded-lg font-bold hover:bg-slate-100 transition-all text-sm lg:text-base shadow-lg"
              >
                Start Disposal Order
              </button>
            </div>
          </div>

          <div id="hardware" class="tab-content">
            <div
              class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm"
            >
              <div class="overflow-x-auto">
                <table class="w-full text-left min-w-[600px]">
                  <thead
                    class="bg-slate-50 text-gray-500 text-[10px] font-black uppercase tracking-widest border-b border-gray-200"
                  >
                    <tr>
                      <th class="px-6 py-4">Asset Identification</th>
                      <th class="px-6 py-4">Serial</th>
                      <th class="px-6 py-4">Status</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-100 text-sm">
                    <tr class="hover:bg-slate-50">
                      <td class="px-6 py-4 font-bold">Standard Workstation</td>
                      <td class="px-6 py-4 text-gray-500">#882-901</td>
                      <td class="px-6 py-4">
                        <span
                          class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter"
                          >In Queue</span
                        >
                      </td>
                    </tr>
                    <tr class="hover:bg-slate-50">
                      <td class="px-6 py-4 font-bold">Mobile Device</td>
                      <td class="px-6 py-4 text-gray-500">#990-212</td>
                      <td class="px-6 py-4">
                        <span
                          class="bg-slate-600 text-white px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter"
                          >Sanitized</span
                        >
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div id="chatbot" class="tab-content h-full">
            <div
              class="max-w-3xl mx-auto flex flex-col h-[70vh] lg:h-[600px] border border-gray-200 rounded-xl bg-white shadow-sm overflow-hidden"
            >
              <div
                class="p-4 bg-slate-50 border-b border-gray-200 font-bold text-sm lg:text-base flex items-center gap-2"
              >
                <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
                Virtual Asset Advisor
              </div>
              <div
                id="chatMessages"
                class="flex-1 p-4 lg:p-6 overflow-y-auto space-y-4 bg-slate-50/50"
              >
                <div class="flex justify-start">
                  <div
                    class="bg-white border border-gray-200 text-gray-800 px-4 py-3 rounded-xl rounded-tl-none text-sm shadow-sm max-w-[90%]"
                  >
                    Hello! How can I help with your assets today?
                  </div>
                </div>
              </div>
              <div class="p-4 border-t border-gray-200 bg-white">
                <div class="flex flex-col sm:flex-row gap-2">
                  <input
                    id="chatInput"
                    type="text"
                    placeholder="Type here..."
                    class="flex-1 border border-gray-200 rounded-lg px-4 py-2 text-sm outline-none focus:border-slate-600"
                  />
                  <button
                    onclick="sendMessage()"
                    class="bg-slate-600 text-white px-6 py-2 rounded-lg font-bold text-sm hover:bg-slate-800 transition-all"
                  >
                    Send
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div id="reports" class="tab-content">
            <div class="grid grid-cols-1 gap-3">
              <div
                class="p-4 lg:p-6 bg-white border border-gray-200 rounded-xl hover:border-slate-600 transition-all cursor-pointer flex justify-between items-center group"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="w-10 h-10 lg:w-12 lg:h-12 bg-slate-100 rounded-lg flex items-center justify-center text-slate-600 group-hover:bg-slate-600 group-hover:text-white transition-all"
